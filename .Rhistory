library(readxl)
library(dplyr)
library(infotheo)
retail_data <- read_excel("C:/Users/dubey/Downloads/Online Retail.xlsx")
retail_clean <- retail_data %>%
filter(!is.na(CustomerID)) %>%
filter(!grepl("^C", InvoiceNo)) %>%
mutate(
TotalAmount = Quantity * UnitPrice,
HighValue = ifelse(
TotalAmount > median(TotalAmount, na.rm = TRUE), 1, 0
)
)
retail_final <- retail_clean
pca_data <- retail_final %>%
select(Quantity, UnitPrice, TotalAmount) %>%
na.omit()
pca_scaled <- scale(pca_data)
pca_model <- prcomp(pca_scaled)
var_exp <- summary(pca_model)$importance[2,]
cum_var <- summary(pca_model)$importance[3,]
