sample_frac(0.10)
dim(sample_random)
cat("\nAdarsh Dubey (R.N.: 2023BCS0117)\nQ1-5(a): Stratified Sample\n")
top_countries <- retail_final %>%
count(Country, sort = TRUE) %>%
slice_head(n = 5) %>%
pull(Country)
sample_strat <- retail_final %>%
filter(Country %in% top_countries) %>%
group_by(Country) %>%
sample_frac(0.10) %>%
ungroup()
dim(sample_strat)
cat("\nAdarsh Dubey (R.N.: 2023BCS0117)\nQ1-5(a): Cluster Sampling\n")
set.seed(42)
k_model <- kmeans(pca_scaled, centers = 10)
retail_final$cluster <- k_model$cluster
sample_cluster <- retail_final %>%
group_by(cluster) %>%
slice_sample(n = max(1, round(0.10 * n()))) %>%
ungroup()
