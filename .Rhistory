cat("\nAdarsh Dubey (R.N.: 2023BCS0117)\nQ1-5(b): Chi-square Test\n")
# Align country levels
full_tab <- table(retail_final$Country)
sample_tab <- table(sample_random$Country)
common_levels <- union(names(full_tab), names(sample_tab))
full_tab <- full_tab[common_levels]
sample_tab <- sample_tab[common_levels]
full_tab[is.na(full_tab)] <- 0
sample_tab[is.na(sample_tab)] <- 0
chisq.test(full_tab, sample_tab)
