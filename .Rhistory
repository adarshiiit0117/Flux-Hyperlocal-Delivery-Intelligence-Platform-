retail_final$price_bin_freq <- infotheo::discretize(
retail_final$UnitPrice,
disc = "equalfreq",
nbins = 10
)
cat("\nAdarsh Dubey (R.N.: 2023BCS0117)\nQ1-7(b)\n")
retail_final <- retail_final %>%
group_by(price_bin_width) %>%
mutate(
price_smooth_mean = mean(UnitPrice, na.rm = TRUE),
price_smooth_median = median(UnitPrice, na.rm = TRUE),
price_smooth_boundary = (min(UnitPrice, na.rm = TRUE) +
max(UnitPrice, na.rm = TRUE)) / 2
) %>%
ungroup()
