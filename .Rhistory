cat("\nAdarsh Dubey (R.N.: 2023BCS0117)\nQ1-7(a)\n")
retail_final$price_bin_width <- cut(retail_final$UnitPrice, breaks = 10)
retail_final$price_bin_freq <- infotheo::discretize(
retail_final$UnitPrice,
disc = "equalfreq",
nbins = 10
)
cat("\nAdarsh Dubey (R.N.: 2023BCS0117)\nQ1-7(b)\n")
retail_final <- retail_final %>%
group_by(price_bin_width) %>%
mutate(
price_smooth_mean = mean(UnitPrice, na.rm = TRUE),
price_smooth_median = median(UnitPrice, na.rm = TRUE),
price_smooth_boundary = (min(UnitPrice, na.rm = TRUE) +
max(UnitPrice, na.rm = TRUE)) / 2
) %>%
ungroup()
cat("\nAdarsh Dubey (R.N.: 2023BCS0117)\nQ1-7(c)\n")
png("smoothing_comparison.png", width = 900, height = 700)
ggplot(retail_final[1:2000, ], aes(x = UnitPrice)) +
geom_line(color = "blue") +
geom_line(aes(y = price_smooth_mean), color = "red") +
ggtitle("Before vs After Smoothing\nAdarsh Dubey (R.N.: 2023BCS0117)")
cat("\nAdarsh Dubey (R.N.: 2023BCS0117)\nQ1-7(c)\n")
png("smoothing_comparison.png", width = 900, height = 700)
ggplot(retail_final[1:2000, ], aes(x = 1:2000)) +
geom_line(aes(y = UnitPrice), color = "blue") +
geom_line(aes(y = price_smooth_mean), color = "red") +
ggtitle("Before vs After Smoothing\nAdarsh Dubey (R.N.: 2023BCS0117)") +
xlab("Index") + ylab("UnitPrice")
dev.off()
browseURL("smoothing_comparison.png")
